# URL base del backend (FastAPI)
VITE_API_URL=http://localhost:8000

# Public Key de MercadoPago (la misma que MP_PUBLIC_KEY del backend, pero
# del lado del cliente esta SÍ es pública a propósito — la Public Key está
# diseñada para vivir en el navegador, nunca el Access Token)
VITE_MP_PUBLIC_KEY=TEST-tu-public-key-de-mercadopago
